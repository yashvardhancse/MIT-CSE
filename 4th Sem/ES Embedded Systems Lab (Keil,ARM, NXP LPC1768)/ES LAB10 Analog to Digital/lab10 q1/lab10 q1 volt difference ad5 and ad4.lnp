--cpu Cortex-M3
".\startup_lpc17xx.o"
".\system_lpc17xx.o"
".\vdiff.o"
--strict --scatter ".\lab10 q1 volt difference ad5 and ad4.sct"
--summary_stderr --info summarysizes --map --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list ".\lab10 q1 volt difference ad5 and ad4.map" -o ".\lab10 q1 volt difference ad5 and ad4.axf"