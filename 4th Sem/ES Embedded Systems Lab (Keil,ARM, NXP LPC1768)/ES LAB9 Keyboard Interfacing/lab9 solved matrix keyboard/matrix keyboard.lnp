--cpu Cortex-M3
".\startup_lpc17xx.o"
".\system_lpc17xx.o"
".\matrix keyboard.o"
--strict --scatter ".\matrix keyboard.sct"
--summary_stderr --info summarysizes --map --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list ".\matrix keyboard.map" -o ".\matrix keyboard.axf"